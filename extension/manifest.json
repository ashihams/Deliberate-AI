{
  "manifest_version": 3,
  "name": "Deliberate",
  "version": "1.0.0",
  "description": "Your personal crypto group chat — AI advisors who know your wallet",
  "action": {
    "default_popup": "dist/index.html"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:8001/*",
    "https://*/*"
  ]
}
