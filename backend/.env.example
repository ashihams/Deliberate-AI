# Copy this file to `.env` (same directory) and fill in real values.
# `.env` itself is git-ignored — never commit it.

# --- LLM (Groq) ---
GROQ_API_KEY=
API_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile

# --- Onchain data (Moralis) ---
MORALIS_API_KEY=

# --- Smart contract (Base Sepolia) ---
CONTRACT_ADDRESS=
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org

# Hex private key WITHOUT the 0x prefix.
# Use a fresh dev/test wallet — never your real funded wallet.
PRIVATE_KEY=

# --- ENS (Sepolia via Alchemy) ---
ENS_PARENT=deliberate.eth
ALCHEMY_API_KEY=

# --- AXL P2P ---
AXL_BASE_PORT=9000

# --- Misc ---
CREWAI_TRACING_ENABLED=false

# --- MongoDB ---
# Format: mongodb+srv://<user>:<password>@<cluster>/<db>?<options>
MONGO_URL=
